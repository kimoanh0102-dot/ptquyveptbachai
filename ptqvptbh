<body class="min-h-screen flex items-center justify-center p-2 md:p-6">
    <div id="game-app" class="w-full max-w-5xl bg-white rounded-[2.5rem] shadow-[0_40px_80px_-20px_rgba(0,0,0,0.2)] border border-gray-100 flex flex-col">
        
